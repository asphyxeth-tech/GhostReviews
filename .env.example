# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it's gitignored. Keep your real keys out of git.
#
# In production these same values live in Vercel:
#   Project -> Settings -> Environment Variables (scope each to Production + Preview).

# Anthropic (Claude API) — review analysis and removal-request drafting
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Outscraper — the ONLY Google reviews + rating-distribution source for the
# web app. (The legacy Nimble fallback was removed — see docs/COST_OVERHAUL.md;
# NIMBLE_API_KEY is no longer read here and can be deleted from Vercel. The
# Tower pipeline still reads it from Tower's own secrets until Tower retires.)
# Single API key, sent as the X-API-KEY header. Pay-as-you-go, with 500
# free reviews/month. https://app.outscraper.com/ (Profile -> API key).
OUTSCRAPER_API_KEY=

# Google Maps Platform — Places API (New) key for FREE prospect discovery
# (business rating + review count + category via Text Search). REQUIRED for the
# /admin discover step — the paid Outscraper search fallback was removed (see
# docs/COST_OVERHAUL.md), so discovery hard-fails without this key. Outscraper
# is still used for the review-pull deep-dive. Enable "Places API (New)" + attach
# billing, and restrict the key to that API only (NO HTTP-referrer/IP restriction
# — it's called server-side from Vercel, which has no fixed IP). Server-only.
# https://console.cloud.google.com/ (APIs & Services -> Credentials)
GOOGLE_MAPS_API_KEY=

# Inngest — background jobs + scheduled (monthly) monitoring scans.
# Both keys come from the Inngest dashboard (the key icon, per environment).
# https://app.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Tower — legacy serverless pipeline for the deep audit. ADMIN-ONLY now (the
# public "Full audit" button was removed) and on the retirement path — see
# docs/COST_OVERHAUL.md §4.5. Optional.
# https://tower.dev/ (generate at app.tower.dev -> team settings -> API Keys)
TOWER_API_KEY=

# Tower app name (defaults to "ghost-reviews" if unset; matches
# the [app].name field in pipeline/Towerfile)
TOWER_APP_NAME=ghost-reviews

# Supabase — customer accounts (magic-link auth) + saved scan history.
# Both must be set together, or auth/dashboard degrade off gracefully.
# Project -> Settings -> API (Project URL + anon/public key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Admin prospecting dashboard (/admin) — internal/dev only ---
# Comma-separated emails allowed into /admin (your magic-link login email).
ADMIN_EMAILS=
# Supabase service-role key — lets the admin routes write the internal
# prospect_scans flywheel table (bypasses RLS). Supabase -> Settings -> API
# -> service_role. SERVER-ONLY secret; never expose to the browser / NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (card-on-file success-fee billing) — server-only ---
# Use TEST keys (sk_test_… / whsec_…) until the whole flow is validated, then
# swap to live. We use Stripe-hosted Checkout, so there is NO publishable key.
# Secret key: Stripe Dashboard (Test mode) -> Developers -> API keys.
STRIPE_SECRET_KEY=
# Webhook signing secret: Stripe -> Developers -> Webhooks -> add endpoint
# https://ghostreviews.app/api/stripe/webhook (events: checkout.session.completed,
# payment_intent.succeeded, payment_intent.payment_failed, charge.refunded)
# -> "Signing secret". Verifies inbound webhooks are genuinely from Stripe.
STRIPE_WEBHOOK_SECRET=

# --- Google Business Profile manager identity ---
# The single Google account a client invites as a "Manager" on their Business
# Profile so we can file removal requests for them. MUST be a sign-in-capable
# Google identity (a Workspace seat, or an email registered as a Google
# Account) — an address merely existing on the domain is NOT automatically a
# usable Google account. Verify it can accept an invite on a test profile first.
# Used in the onboarding walkthrough + admin panel. Defaults to devon@ghostreviews.app.
GBP_MANAGER_EMAIL=devon@ghostreviews.app

# --- Resend (transactional email) — server-only ---
# Sends the customer their removal + receipt confirmation when a success fee is
# charged (and is the place to wire other transactional mail later). Optional:
# if unset, the charge flow falls back to showing the operator a copy-paste
# notice to send by hand. API key: https://resend.com/ (Dashboard -> API Keys).
# Keep TRANSACTIONAL mail on the ghostreviews.app domain; send cold OUTREACH from
# a SEPARATE subdomain so a reputation hit can't take down customer/auth mail.
RESEND_API_KEY=
# Optional From override (must be a Resend-verified sender on your domain).
# Defaults to "Ghost Reviews <devon@ghostreviews.app>".
RESEND_FROM=
