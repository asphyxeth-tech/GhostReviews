# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it's gitignored. Keep your real keys out of git.
#
# In production these same values live in Vercel:
#   Project -> Settings -> Environment Variables (scope each to Production + Preview).

# Anthropic (Claude API) — review analysis and removal-request drafting
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Outscraper — primary Google reviews + rating-distribution source.
# Single API key, sent as the X-API-KEY header. Pay-as-you-go, with 500
# free reviews/month. https://app.outscraper.com/ (Profile -> API key).
OUTSCRAPER_API_KEY=

# Nimble — legacy Google reviews scraper, kept as an automatic fallback if
# Outscraper is unavailable. Optional once Outscraper is configured.
# https://nimbleway.com/
NIMBLE_API_KEY=

# Google Maps Platform — Places API (New) key for FREE prospect discovery
# (business rating + review count + category via Text Search). When set, the
# /admin discover step uses this instead of Outscraper's paid search; Outscraper
# is still used for the review-pull deep-dive. Enable "Places API (New)" + attach
# billing, and restrict the key to that API only (NO HTTP-referrer/IP restriction
# — it's called server-side from Vercel, which has no fixed IP). Server-only.
# https://console.cloud.google.com/ (APIs & Services -> Credentials)
GOOGLE_MAPS_API_KEY=

# Inngest — background jobs + scheduled (monthly) monitoring scans.
# Both keys come from the Inngest dashboard (the key icon, per environment).
# https://app.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Tower — legacy serverless pipeline for the deep audit (being migrated to
# Inngest). Optional; the "Full audit" button uses it when set.
# https://tower.dev/ (generate at app.tower.dev -> team settings -> API Keys)
TOWER_API_KEY=

# Tower app name (defaults to "ghost-reviews" if unset; matches
# the [app].name field in pipeline/Towerfile)
TOWER_APP_NAME=ghost-reviews

# Supabase — customer accounts (magic-link auth) + saved scan history.
# Both must be set together, or auth/dashboard degrade off gracefully.
# Project -> Settings -> API (Project URL + anon/public key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Admin prospecting dashboard (/admin) — internal/dev only ---
# Comma-separated emails allowed into /admin (your magic-link login email).
ADMIN_EMAILS=
# Supabase service-role key — lets the admin routes write the internal
# prospect_scans flywheel table (bypasses RLS). Supabase -> Settings -> API
# -> service_role. SERVER-ONLY secret; never expose to the browser / NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=
