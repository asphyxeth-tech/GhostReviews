# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it's gitignored. Keep your real keys out of git.

# Anthropic (Claude API) — used for review analysis and removal-request drafting
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Nimble — used to scrape Google reviews
# https://nimbleway.com/
NIMBLE_API_KEY=

# Tower — used to run the scrape -> analyze pipeline
# https://tower.dev/
TOWER_API_KEY=
